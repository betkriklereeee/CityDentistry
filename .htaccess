Options -MultiViews
RewriteEngine On
RewriteBase /citydentistry/

# Remove .html extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# Redirect .html URLs to clean URLs
RewriteCond %{THE_REQUEST} \s/+citydentistry/([^.]+)\.html[\s?] [NC]
RewriteRule ^ /citydentistry/%1 [R=301,L]